{
  "name": "@ellenode/maily",
  "version": "1.0.6",
  "description": "Maily es un paquete minimalista para el envío de correos electrónicos en Node.js utilizando nodemailer, con soporte para plantillas HTML basadas en Handlebars y una sintaxis fluida y sencilla.",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "npm run build && node test/maily.mjs",
    "build": "rollup -c",
    "prepare": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CrisGuzmanS/maily.git"
  },
  "keywords": [
    "maily",
    "emails",
    "mails",
    "minimalist",
    "minimalista",
    "correos"
  ],
  "author": "Cristian Emanuelle Guzmán Suárez",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/CrisGuzmanS/maily/issues"
  },
  "homepage": "https://github.com/CrisGuzmanS/maily#readme",
  "dependencies": {
    "@ellenode/envy": "^0.0.1",
    "handlebars": "^4.7.9",
    "nodemailer": "^8.0.7"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "rollup": "^4.60.3"
  }
}
